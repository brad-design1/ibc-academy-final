---
// Standalone landing page — NO navigation, NO escape routes
// CRO-optimized for 40+ demographic
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Free IBC Workshop | The 34.5% Problem</title>
  <meta name="description" content="Free 45-minute workshop: Learn why 34.5 cents of every dollar goes to interest — and how to flip that equation. No pitch, no pressure.">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] },
          colors: {
            gold: { DEFAULT: '#B8860B', light: '#D4A84B', dark: '#8B6914' }
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', system-ui, sans-serif; }
    .fade-in { animation: fadeIn 0.5s ease-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body class="bg-gradient-to-b from-slate-50 to-white min-h-screen">

  <main class="max-w-3xl mx-auto px-4 py-8 lg:py-12">

    <!-- Minimal branding (no link) -->
    <div class="text-center mb-8">
      <span class="text-xl font-bold text-slate-800">IBC<span class="text-gold">Academy</span></span>
    </div>

    <!-- Hero -->
    <section class="text-center mb-12 fade-in">
      <!-- Live badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-50 border border-red-200 mb-6">
        <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
        <span class="text-red-700 text-sm font-semibold">Free Live Workshop</span>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-tight mb-4">
        The <span class="text-gold">34.5% Problem</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-600 mb-6">
        Why You Finance Everything You Buy<br>
        <span class="text-slate-500">(Even When You Pay Cash)</span>
      </p>

      <!-- Time slots -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-8">
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white border border-slate-200 shadow-sm">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="font-semibold text-slate-800">Tuesday 12:00 PM CT</span>
        </div>
        <span class="text-slate-400">or</span>
        <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white border border-slate-200 shadow-sm">
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <span class="font-semibold text-slate-800">Wednesday 7:00 PM CT</span>
        </div>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-500 mb-8">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          NNI Authorized
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          No pitch
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3z" />
          </svg>
          45 minutes
        </span>
      </div>
    </section>

    <!-- What You'll Learn -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-slate-800 text-center mb-6">
        In This Free Workshop, You'll Discover:
      </h2>
      <div class="space-y-3">
        <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-slate-100 shadow-sm">
          <div class="w-8 h-8 rounded-lg bg-gold/10 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-gold font-bold">1</span>
          </div>
          <div>
            <p class="font-semibold text-slate-800">The math behind "34.5 cents of every dollar"</p>
            <p class="text-sm text-slate-500">Why most people never see this hidden cost</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-slate-100 shadow-sm">
          <div class="w-8 h-8 rounded-lg bg-gold/10 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-gold font-bold">2</span>
          </div>
          <div>
            <p class="font-semibold text-slate-800">Why "paying cash" and "financing" cost the same</p>
            <p class="text-sm text-slate-500">Nelson Nash's key insight that changes everything</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-slate-100 shadow-sm">
          <div class="w-8 h-8 rounded-lg bg-gold/10 flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-gold font-bold">3</span>
          </div>
          <div>
            <p class="font-semibold text-slate-800">The "banking function" banks use to build wealth</p>
            <p class="text-sm text-slate-500">And how you can capture it for yourself</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Registration Form -->
    <section id="register" class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 lg:p-8 mb-8">
      <h2 class="text-xl font-bold text-slate-800 text-center mb-2">Reserve Your Seat</h2>
      <p class="text-slate-500 text-center text-sm mb-6">Choose your preferred time</p>
      
      <form id="webinar-form" class="space-y-4">
        <!-- Time Selection -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="cursor-pointer">
            <input type="radio" name="session" value="tuesday" class="peer hidden" checked />
            <div class="p-4 rounded-xl border-2 border-slate-200 peer-checked:border-gold peer-checked:bg-gold/5 transition-all text-center">
              <p class="font-semibold text-slate-800">Tuesday</p>
              <p class="text-sm text-slate-500">12:00 PM CT</p>
            </div>
          </label>
          <label class="cursor-pointer">
            <input type="radio" name="session" value="wednesday" class="peer hidden" />
            <div class="p-4 rounded-xl border-2 border-slate-200 peer-checked:border-gold peer-checked:bg-gold/5 transition-all text-center">
              <p class="font-semibold text-slate-800">Wednesday</p>
              <p class="text-sm text-slate-500">7:00 PM CT</p>
            </div>
          </label>
        </div>

        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-slate-700 mb-1">First Name</label>
          <input type="text" id="name" name="name" required
            class="w-full px-4 py-3 rounded-xl border-2 border-slate-200 focus:border-gold focus:ring-0 transition-colors text-slate-800 text-lg"
            placeholder="Your first name" />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full px-4 py-3 rounded-xl border-2 border-slate-200 focus:border-gold focus:ring-0 transition-colors text-slate-800 text-lg"
            placeholder="you@example.com" />
        </div>

        <!-- Submit -->
        <button type="submit" id="submit-btn"
          class="w-full py-4 bg-gold hover:bg-gold-dark text-white font-bold text-lg rounded-xl transition-colors shadow-lg shadow-gold/25">
          <span id="btn-text">Register Free →</span>
          <span id="btn-loading" class="hidden">
            <svg class="animate-spin inline w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            Registering...
          </span>
        </button>

        <!-- Error -->
        <div id="error-msg" class="hidden p-3 rounded-lg bg-red-50 text-red-700 text-sm text-center"></div>
      </form>

      <!-- Success State (hidden initially) -->
      <div id="success-state" class="hidden text-center py-8">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-800 mb-2">You're Registered!</h3>
        <p class="text-slate-600 mb-4">Check your email for the Zoom link.</p>
        <p id="session-confirm" class="text-sm text-slate-500"></p>
      </div>

      <p class="text-xs text-slate-400 text-center mt-4">No spam. Unsubscribe anytime.</p>
    </section>

    <!-- About Brad -->
    <section class="text-center mb-8">
      <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-slate-200 flex items-center justify-center">
        <span class="text-2xl font-bold text-slate-500">BR</span>
      </div>
      <h3 class="font-bold text-slate-800 mb-1">Brad Raschke</h3>
      <p class="text-sm text-slate-500 mb-3">NNI Authorized IBC Practitioner</p>
      <p class="text-sm text-slate-600 max-w-md mx-auto">
        Brad helps families and business owners implement the Infinite Banking Concept — the wealth-building strategy pioneered by Nelson Nash.
      </p>
    </section>

    <!-- Footer -->
    <footer class="text-center text-xs text-slate-400 pt-8 border-t border-slate-100">
      <p>© 2026 IBC Academy. Education only — not financial advice.</p>
    </footer>

  </main>

  <script>
    const form = document.getElementById('webinar-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnLoading = document.getElementById('btn-loading');
    const errorMsg = document.getElementById('error-msg');
    const successState = document.getElementById('success-state');
    const sessionConfirm = document.getElementById('session-confirm');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnLoading.classList.remove('hidden');

      const formData = new FormData(form);
      const session = formData.get('session');
      const name = formData.get('name');
      const email = formData.get('email');

      try {
        // Try API first
        const res = await fetch('/api/register-webinar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, firstName: name, session })
        });

        if (res.ok) {
          showSuccess(session);
          return;
        }
        throw new Error('API failed');
      } catch (err) {
        // Fallback to Formspree
        try {
          const fallback = await fetch('https://formspree.io/f/mpwzgvvd', {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });
          if (fallback.ok) {
            showSuccess(session);
            return;
          }
        } catch (e) {}
        
        errorMsg.textContent = 'Something went wrong. Please try again.';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
      }
    });

    function showSuccess(session) {
      form.classList.add('hidden');
      successState.classList.remove('hidden');
      const day = session === 'tuesday' ? 'Tuesday at 12:00 PM CT' : 'Wednesday at 7:00 PM CT';
      sessionConfirm.textContent = `See you ${day}!`;
    }
  </script>

</body>
</html>
