---
import Layout from '../../layouts/Layout.astro';

// Google Calendar Appointment Scheduling - using popup button approach
const bookingUrl = "https://calendar.app.google/H2wTUKcJnuhkpxFy8";
---

<Layout title="Pick a Time | IBC Academy" description="Schedule your free strategy call with Brad.">

  <!-- Google Calendar Appointment Scheduling Script -->
  <link href="https://calendar.google.com/calendar/scheduling-button-script.css" rel="stylesheet">
  <script src="https://calendar.google.com/calendar/scheduling-button-script.js" async></script>

  <section class="py-12 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up text-center mb-10">
        <!-- Success Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 mb-6">
          <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-green-700 text-sm font-semibold">Information Received</span>
        </div>

        <!-- Headline -->
        <h1 class="text-3xl sm:text-4xl font-extrabold text-[#1A1A1A]">
          Now Pick a <span class="text-[#B8860B]">Time</span>
        </h1>
        <p class="mt-3 text-lg text-[#4A4A4A]">
          Brad received your info. Click below to schedule your call — opens right here, no redirect.
        </p>
      </div>

      <!-- Main Booking Card -->
      <div class="fade-in-up glass-card rounded-2xl p-8 text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#B8860B]/10 flex items-center justify-center">
          <svg class="w-8 h-8 text-[#B8860B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>

        <h2 class="text-xl font-bold text-[#1A1A1A] mb-2">30-Minute Strategy Call</h2>
        <p class="text-[#6B6B6B] mb-6">Free • Via Zoom • No Obligation</p>

        <!-- Google Calendar Popup Button -->
        <div id="calendar-button-container" class="mb-4">
          <button 
            id="schedule-btn"
            onclick="openCalendarPopup()"
            class="inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-gold to-gold-dark text-navy-900 font-extrabold text-xl rounded-xl hover:from-gold-light hover:to-gold transition-all duration-300 shadow-lg shadow-gold/30 hover:shadow-gold/50 hover:scale-[1.02]"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Pick a Time
          </button>
        </div>

        <p class="text-xs text-[#6B6B6B]">Opens Google Calendar in a popup — stays on this page</p>
      </div>

      <!-- What to expect -->
      <div class="fade-in-up mt-10 grid md:grid-cols-3 gap-4">
        <div class="glass-card rounded-xl p-5 text-center">
          <div class="w-10 h-10 rounded-full bg-[#B8860B]/10 flex items-center justify-center mx-auto mb-3">
            <span class="text-[#B8860B] font-bold">1</span>
          </div>
          <p class="text-sm font-semibold text-[#1A1A1A]">Pick a Time</p>
          <p class="text-xs text-[#6B6B6B] mt-1">Choose what works for you</p>
        </div>

        <div class="glass-card rounded-xl p-5 text-center">
          <div class="w-10 h-10 rounded-full bg-[#B8860B]/10 flex items-center justify-center mx-auto mb-3">
            <span class="text-[#B8860B] font-bold">2</span>
          </div>
          <p class="text-sm font-semibold text-[#1A1A1A]">Get Zoom Link</p>
          <p class="text-xs text-[#6B6B6B] mt-1">Sent to your email instantly</p>
        </div>

        <div class="glass-card rounded-xl p-5 text-center">
          <div class="w-10 h-10 rounded-full bg-[#B8860B]/10 flex items-center justify-center mx-auto mb-3">
            <span class="text-[#B8860B] font-bold">3</span>
          </div>
          <p class="text-sm font-semibold text-[#1A1A1A]">Talk to Brad</p>
          <p class="text-xs text-[#6B6B6B] mt-1">Education, not sales</p>
        </div>
      </div>

      <!-- Alternative -->
      <div class="fade-in-up mt-10 text-center text-sm text-[#6B6B6B]">
        <p>Not ready to schedule? No problem — Brad will follow up by email.</p>
        <p class="mt-2">
          In the meantime: 
          <a href="/learn/start-here" class="text-[#B8860B] hover:underline">explore IBC basics</a> or 
          <a href="/webinar" class="text-[#B8860B] hover:underline">join the free webinar</a>.
        </p>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ bookingUrl }}>
    function openCalendarPopup() {
      // Open Google Calendar in a centered popup window
      const width = 600;
      const height = 700;
      const left = (window.innerWidth - width) / 2 + window.screenX;
      const top = (window.innerHeight - height) / 2 + window.screenY;
      
      window.open(
        bookingUrl,
        'Schedule Call',
        `width=${width},height=${height},left=${left},top=${top},scrollbars=yes,resizable=yes`
      );
    }
  </script>

</Layout>
