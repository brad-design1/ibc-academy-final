---
import Layout from '../../layouts/Layout.astro';

const bookingUrl = "https://calendar.app.google/H2wTUKcJnuhkpxFy8";
---

<Layout title="One More Step | IBC Academy" description="Pick a time for your strategy call with Brad.">

  <section class="min-h-[70vh] flex items-center py-16 lg:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="fade-in-up">
        <!-- Progress Icon -->
        <div class="w-20 h-20 mx-auto mb-8 rounded-full bg-[#B8860B]/10 flex items-center justify-center">
          <svg class="w-10 h-10 text-[#B8860B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl font-extrabold text-[#1A1A1A]">
          Almost There — <span class="text-[#B8860B]">Pick a Time</span>
        </h1>
        <p class="mt-4 text-xl text-[#4A4A4A]">
          Brad received your information. Now choose a time that works for you.
        </p>

        <!-- Calendar CTA -->
        <div class="mt-8">
          <a 
            href={bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-gold to-gold-dark text-navy-900 font-extrabold text-xl rounded-xl hover:from-gold-light hover:to-gold transition-all duration-300 shadow-lg shadow-gold/30 hover:shadow-gold/50 hover:scale-[1.02]"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Schedule Your Call Now
          </a>
          <p class="mt-4 text-sm text-[#6B6B6B]">
            30 minutes • Via Zoom • No obligation
          </p>
        </div>

        <!-- What to expect -->
        <div class="mt-10 glass-card rounded-2xl p-6 text-left">
          <h2 class="font-bold text-[#1A1A1A] mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-[#B8860B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            What happens next:
          </h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#B8860B]/10 flex items-center justify-center text-[#B8860B] font-bold text-sm shrink-0">1</span>
              <span class="text-[#4A4A4A]">Click the button above to pick a time on Brad's calendar</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#B8860B]/10 flex items-center justify-center text-[#B8860B] font-bold text-sm shrink-0">2</span>
              <span class="text-[#4A4A4A]">You'll receive a calendar invite with a Zoom link</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="w-6 h-6 rounded-full bg-[#B8860B]/10 flex items-center justify-center text-[#B8860B] font-bold text-sm shrink-0">3</span>
              <span class="text-[#4A4A4A]">Brad reviews your questionnaire before the call so you can jump right in</span>
            </li>
          </ul>
        </div>

        <!-- Alternative -->
        <div class="mt-8 text-sm text-[#6B6B6B]">
          <p>Not ready to schedule? No problem — Brad will follow up by email.</p>
          <p class="mt-2">
            In the meantime: 
            <a href="/learn/start-here" class="text-[#B8860B] hover:underline">explore IBC basics</a> or 
            <a href="/webinar" class="text-[#B8860B] hover:underline">join the free webinar</a>.
          </p>
        </div>
      </div>
    </div>
  </section>

</Layout>
