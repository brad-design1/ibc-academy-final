---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Discovery Call | IBC Academy" description="Answer a few quick questions to see if a strategy call makes sense for your situation.">

  <section class="relative overflow-hidden py-16 lg:py-24">
    <div class="absolute inset-0 bg-gradient-to-br from-[#FAF9F6] via-navy-light/10 to-[#FAF9F6]"></div>
    
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up text-center mb-10">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#B8860B]/10 border border-[#B8860B]/20 mb-6">
          <svg class="w-4 h-4 text-[#B8860B]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          <span class="text-[#B8860B] text-sm font-semibold">Free Strategy Call</span>
        </div>

        <h1 class="text-4xl sm:text-5xl font-extrabold text-[#1A1A1A] leading-tight">
          Let's See If We're a <span class="text-[#B8860B]">Good Fit</span>
        </h1>
        <p class="mt-4 text-xl text-[#4A4A4A] max-w-2xl mx-auto">
          Answer a few quick questions so Brad can prepare for our conversation. Takes about 2 minutes.
        </p>
      </div>

      <!-- Qualification Form -->
      <div class="fade-in-up glass-card rounded-2xl p-8 shadow-xl">
        <form id="discovery-form" class="space-y-6">
          <!-- Contact Info -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="first_name" class="block text-sm font-medium text-[#4A4A4A] mb-1">First Name *</label>
              <input type="text" id="first_name" name="first_name" required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none"
                placeholder="Your first name" />
            </div>
            <div>
              <label for="last_name" class="block text-sm font-medium text-[#4A4A4A] mb-1">Last Name *</label>
              <input type="text" id="last_name" name="last_name" required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none"
                placeholder="Your last name" />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-[#4A4A4A] mb-1">Email Address *</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none"
              placeholder="you@example.com" />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-[#4A4A4A] mb-1">Phone Number</label>
            <input type="tel" id="phone" name="phone"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none"
              placeholder="(555) 123-4567" />
          </div>

          <div class="border-t border-slate-200 pt-6">
            <p class="text-sm font-semibold text-[#6B6B6B] uppercase tracking-wider mb-4">Help Brad prepare for your call:</p>
          </div>

          <!-- Q1: IBC Familiarity -->
          <div>
            <label for="ibc_familiarity" class="block text-sm font-medium text-[#4A4A4A] mb-1">How familiar are you with IBC? *</label>
            <select id="ibc_familiarity" name="ibc_familiarity" required
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none bg-white">
              <option value="">Select an option...</option>
              <option value="brand_new">Brand new — just heard about it</option>
              <option value="researching">I've been researching online</option>
              <option value="read_byob">I've read Becoming Your Own Banker</option>
              <option value="have_policy">I already have a policy (looking for guidance)</option>
            </select>
          </div>

          <!-- Q2: Interest trigger -->
          <div>
            <label for="interest_trigger" class="block text-sm font-medium text-[#4A4A4A] mb-1">What's prompting your interest? *</label>
            <select id="interest_trigger" name="interest_trigger" required
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none bg-white">
              <option value="">Select an option...</option>
              <option value="wealth_building">Building long-term wealth</option>
              <option value="business_capital">Need capital for business</option>
              <option value="real_estate">Real estate investing</option>
              <option value="debt_payoff">Getting out of debt</option>
              <option value="retirement">Retirement planning</option>
              <option value="legacy">Legacy / family wealth</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Q3: Monthly capacity -->
          <div>
            <label for="monthly_capacity" class="block text-sm font-medium text-[#4A4A4A] mb-1">Monthly budget for a policy? *</label>
            <select id="monthly_capacity" name="monthly_capacity" required
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none bg-white">
              <option value="">Select an option...</option>
              <option value="under_500">Under $500/month</option>
              <option value="500_1000">$500 - $1,000/month</option>
              <option value="1000_2500">$1,000 - $2,500/month</option>
              <option value="2500_plus">$2,500+/month</option>
              <option value="not_sure">Not sure yet</option>
            </select>
          </div>

          <!-- Q4: Timeline -->
          <div>
            <label for="timeline" class="block text-sm font-medium text-[#4A4A4A] mb-1">How soon to get started? *</label>
            <select id="timeline" name="timeline" required
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none bg-white">
              <option value="">Select an option...</option>
              <option value="asap">As soon as possible</option>
              <option value="1_3_months">Within 1-3 months</option>
              <option value="3_6_months">3-6 months</option>
              <option value="just_learning">Just learning for now</option>
            </select>
          </div>

          <!-- Q5: Additional context -->
          <div>
            <label for="questions" class="block text-sm font-medium text-[#4A4A4A] mb-1">Anything else Brad should know?</label>
            <textarea id="questions" name="questions" rows="3"
              class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-[#B8860B] focus:ring-2 focus:ring-[#B8860B]/20 transition-all outline-none resize-none"
              placeholder="Your situation, questions, or concerns..."></textarea>
          </div>

          <!-- Submit -->
          <button type="submit" id="submit-btn"
            class="w-full px-6 py-4 bg-gradient-to-r from-gold to-gold-dark text-navy-900 font-extrabold text-lg rounded-xl hover:from-gold-light hover:to-gold transition-all duration-300 shadow-lg shadow-gold/30 hover:shadow-gold/50 hover:scale-[1.02] disabled:opacity-50 disabled:cursor-not-allowed">
            <span id="btn-text">Submit & Schedule Your Call</span>
            <span id="btn-loading" class="hidden">
              <svg class="animate-spin inline w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Submitting...
            </span>
          </button>

          <!-- Error message -->
          <div id="error-message" class="hidden p-4 rounded-xl bg-red-50 border border-red-200 text-red-700 text-sm"></div>
        </form>

        <p class="mt-4 text-xs text-[#6B6B6B] text-center">
          No spam. No pressure. This call is about education, not sales.
        </p>
      </div>

      <!-- What to expect -->
      <div class="fade-in-up mt-12 text-center">
        <h2 class="text-xl font-bold text-[#1A1A1A] mb-4">What to expect on the call:</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          <div class="glass-card rounded-xl p-4">
            <div class="w-10 h-10 rounded-full bg-[#B8860B]/10 flex items-center justify-center mx-auto mb-3">
              <span class="text-[#B8860B] font-bold">1</span>
            </div>
            <p class="text-sm text-[#4A4A4A]">Brad reviews your situation and answers questions</p>
          </div>
          <div class="glass-card rounded-xl p-4">
            <div class="w-10 h-10 rounded-full bg-[#B8860B]/10 flex items-center justify-center mx-auto mb-3">
              <span class="text-[#B8860B] font-bold">2</span>
            </div>
            <p class="text-sm text-[#4A4A4A]">You learn if IBC is right for your goals</p>
          </div>
          <div class="glass-card rounded-xl p-4">
            <div class="w-10 h-10 rounded-full bg-[#B8860B]/10 flex items-center justify-center mx-auto mb-3">
              <span class="text-[#B8860B] font-bold">3</span>
            </div>
            <p class="text-sm text-[#4A4A4A]">No pressure — next steps are your choice</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('discovery-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnLoading = document.getElementById('btn-loading');
    const errorMessage = document.getElementById('error-message');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Reset error state
      errorMessage.classList.add('hidden');
      submitBtn.disabled = true;
      btnText.classList.add('hidden');
      btnLoading.classList.remove('hidden');
      
      const formData = new FormData(form);
      
      // Collect intent signals for thank-you page
      const intentParams = new URLSearchParams({
        name: formData.get('first_name'),
        familiarity: formData.get('ibc_familiarity'),
        interest: formData.get('interest_trigger'),
        capacity: formData.get('monthly_capacity'),
        timeline: formData.get('timeline')
      });
      
      try {
        // Try our API first
        const response = await fetch('/api/capture-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: formData.get('email'),
            firstName: formData.get('first_name'),
            lastName: formData.get('last_name'),
            phone: formData.get('phone'),
            source: 'discovery',
            ibcFamiliarity: formData.get('ibc_familiarity'),
            interestTrigger: formData.get('interest_trigger'),
            monthlyCapacity: formData.get('monthly_capacity'),
            timeline: formData.get('timeline'),
            questions: formData.get('questions')
          })
        });
        
        const result = await response.json();
        
        if (result.success || response.ok) {
          // Track conversion
          if (typeof gtag === 'function') {
            gtag('event', 'discovery_request', {
              timeline: formData.get('timeline'),
              capacity: formData.get('monthly_capacity')
            });
          }
          
          // Redirect with intent params for dynamic thank-you page
          window.location.href = `/discovery/thank-you?${intentParams.toString()}`;
          return;
        }
        
        throw new Error(result.error || 'Submission failed');
        
      } catch (err) {
        console.error('API failed, trying Formspree fallback:', err);
        
        // Fallback to Formspree
        try {
          const formspreeResponse = await fetch('https://formspree.io/f/mpwzgvvd', {
            method: 'POST',
            body: formData,
            headers: { 'Accept': 'application/json' }
          });
          
          if (formspreeResponse.ok) {
            window.location.href = `/discovery/thank-you?${intentParams.toString()}`;
            return;
          }
        } catch (fallbackErr) {
          console.error('Formspree also failed:', fallbackErr);
        }
        
        // Show error if both failed
        errorMessage.textContent = 'Something went wrong. Please try again or email support@ibcacademy.org';
        errorMessage.classList.remove('hidden');
        submitBtn.disabled = false;
        btnText.classList.remove('hidden');
        btnLoading.classList.add('hidden');
      }
    });
  </script>

</Layout>
